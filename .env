# ==========================================
# AI 配置
# ==========================================
# API Key (示例: sk-12345678901234567890123456789012)
OPENAI_API_KEY=

# API 基础 URL, 可选其他模型, 例如openai官方: https://api.openai.com/v1 (默认: deepseek 官方接口)
OPENAI_BASE_URL=https://api.deepseek.com/v1
# 模型名称, 可选其他模型, 例如openai官方: gpt-4o-mini (默认: deepseek-chat)
MODEL=deepseek-chat
# agent 最大思考次数(默认: 10)
MAX_TURNS=10

# ==========================================
# agent文件输入配置
# ==========================================
# 是否启用文件轮询模式 (true/false, 默认: false)
FILE_POLLER=false
# 输入文件路径 (默认: ./agent-input.txt)
AGENT_INPUT=./agent-input.txt

# ==========================================
# 网关配置
# ==========================================
# 网关端口 (默认: 3000)
GATEWAY_PORT=3000
# 网关启动命令 (默认: node --env-file=.env src/gateway.ts)
GATEWAY_CMD=node --env-file=.env src/gateway.ts
# 网关重启策略 (never/on-failure/always, 默认: always)
GATEWAY_RESTART_POLICY=always
# 网关崩溃日志路径 (默认: ./logs/gateway-crash.log)
GATEWAY_LOGS_PATH=./logs/gateway-crash.log