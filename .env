# ==========================================
# AI 配置
# ==========================================
# API Key **核心必填项** (示例: sk-12345678901234567890123456789012)
API_KEY=

# API URL, 可选其他模型, 例如openai官方: https://api.openai.com/v1 (默认: deepseek 官方接口)
BASE_URL=https://api.deepseek.com/v1
# 模型名称, 可选其他模型, 例如openai官方: gpt-4o-mini (默认: deepseek-chat)
MODEL=deepseek-chat
# Agent 最大思考次数 (默认: 10)
MAX_TURNS=10

# ==========================================
# 执行配置
# ==========================================
# 命令执行超时时间，单位毫秒 (默认: 60000)
TIMEOUT=60000

# ==========================================
# Agent 文件输入配置
# ==========================================
# 是否启用文件轮询模式 (true/false, 默认: false)
FILE_POLLER=false
# 输入文件路径 (默认: ./agent-input.txt)
INPUT_FILE=./agent-input.txt
# 轮询间隔，单位毫秒 (默认: 2000)
POLL_INTERVAL=2000

# ==========================================
# 网关配置
# ==========================================
# 网关端口,在gateway里面使用 (默认: 3000)
GATEWAY_PORT=3000
# 网关启动命令 (默认: npm run gateway)
GATEWAY_CMD=npm run gateway
# 网关重启策略 (never/on-failure/always, 默认: always)
GATEWAY_RESTART_POLICY=always
# 网关崩溃日志路径 (默认: ./logs/gateway-crash.log)
GATEWAY_LOGS_PATH=./logs/gateway-crash.log

# ==========================================
# 以下配置项无需配置，但如果你想的话，也可以🤔
# ==========================================
# shell执行器 (生成代码: os.platform() === 'win32' ? 'cmd.exe' : '/bin/bash' )
# SHELL=
# shell执行器的标识 (生成代码: os.platform() === 'win32' ? '/c' : '-c' )
# SHELL_FLAG=
# agent的id，会自增, 用于打印日志 (默认: 0 )
# agentId=0
# 重置颜色 (默认: '\x1b[0m' )
# COLORS_RESET='\x1b[0m'